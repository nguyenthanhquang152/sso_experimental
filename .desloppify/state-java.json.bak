    "review::.::holistic::type_safety::microsoft_claims_use_untyped_map_coercion": {
      "id": "review::.::holistic::type_safety::microsoft_claims_use_untyped_map_coercion",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Microsoft claim validation relies on `Map<String,Object>` and string coercion instead of typed claims",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/MicrosoftTokenVerifier.java",
          "backend/src/main/java/com/demo/sso/service/ProviderIdentityNormalizer.java"
        ],
        "evidence": [
          "`MicrosoftTokenVerifier.verifyIdToken(...)` passes `jwt.getClaims()` straight into `normalizeMicrosoftClaims(Map<String, Object>, ...)`, so the contract for required claim shapes is only implicit.",
          "`ProviderIdentityNormalizer.stringClaim(...)` returns `String.valueOf(value)` for any non-null object, so non-string claim payloads are silently coerced to text instead of being rejected as the wrong type.",
          "`MicrosoftTokenVerifier` also validates `iss`, `tid`, `ver`, and `nonce` via `String.valueOf(jwt.getClaims().get(...))`, which erases the distinction between missing, wrongly typed, and correctly typed claims."
        ],
        "suggestion": "Introduce a typed Microsoft-claims adapter/value object (or use explicit `instanceof String` checks before normalization) so required OIDC claims are validated with real types instead of coercing arbitrary objects into strings.",
        "reasoning": "",
        "summary_hash": "66638833"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-14T19:10:42+00:00",
      "last_seen": "2026-03-14T19:10:42+00:00",
      "resolved_at": "2026-03-15T02:05:07+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
