    "review::.::holistic::dependency_health::dual_jwt_libraries": {
      "id": "review::.::holistic::dependency_health::dual_jwt_libraries",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Two distinct JWT libraries (jjwt + Spring Security OAuth2 JWT/Nimbus) serve the same conceptual domain",
      "detail": {
        "holistic": true,
        "dimension": "dependency_health",
        "related_files": [
          "backend/pom.xml",
          "backend/src/main/java/com/demo/sso/service/token/JwtTokenService.java",
          "backend/src/main/java/com/demo/sso/service/token/MicrosoftTokenVerifier.java"
        ],
        "evidence": [
          "JwtTokenService uses io.jsonwebtoken (jjwt) for application JWT minting and validation. MicrosoftTokenVerifier uses org.springframework.security.oauth2.jwt.NimbusJwtDecoder for Microsoft ID token verification. Both are JWT processing libraries operating within the same service/token package."
        ],
        "suggestion": "Consider whether MicrosoftTokenVerifier could use jjwt with manual JWKS fetching, or conversely whether JwtTokenService could use Spring Security's JWT infrastructure. Consolidating to one JWT library would reduce the cognitive load and transitive dependency surface.",
        "reasoning": "",
        "summary_hash": "9c19945d"
      },
      "status": "wontfix",
      "note": "All three are significant architectural changes requiring new test infrastructure or fundamental provider wiring redesign \u2014 beyond code quality improvement scope",
