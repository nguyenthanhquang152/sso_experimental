      },
      "wontfix_scan_count": 7,
      "wontfix_snapshot": {
        "captured_at": "2026-03-15T02:53:53+00:00",
        "scan_count": 7,
        "tier": 1,
        "confidence": "high",
        "detail": {
          "holistic": true,
          "dimension": "type_safety",
          "related_files": [
            "frontend/src/api/client.ts"
          ],
          "evidence": [
            "Line with `return undefined as T` \u2014 the function signature is `Promise<T>` not `Promise<T | undefined>`",
            "Comment documents the behavior but TypeScript type system does not protect callers",
            "Any caller expecting a non-undefined T from a 204 endpoint would get a runtime surprise"
          ],
          "suggestion": "Change the return type to `Promise<T | undefined>` or provide a separate `apiFetchNoContent` function for endpoints that return 204. This forces callers to handle the undefined case.",
          "reasoning": "",
          "summary_hash": "c57e6aac"
        }
      }
    },
    "review::.::holistic::type_safety::google_payload_unchecked_cast": {
      "id": "review::.::holistic::type_safety::google_payload_unchecked_cast",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "GoogleTokenVerifier.verify() uses unchecked (String) casts on Google SDK payload values that may not be strings",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/token/GoogleTokenVerifier.java"
        ],
        "evidence": [
          "`(String) payload.get(\"name\")` and `(String) payload.get(\"picture\")` cast Object to String without instanceof check",
          "Google's Payload.get() returns Object \u2014 if the payload shape changes or contains a non-String value, ClassCastException at runtime",
          "Contrast with MicrosoftIdTokenClaims.stringClaim() which safely handles non-String values via instanceof and String.valueOf()"
        ],
        "suggestion": "Use the same safe-cast pattern as MicrosoftIdTokenClaims.stringClaim(): check `instanceof String s` and fall back to `String.valueOf(value)` for non-null non-String values. This also aligns the two providers' claim extraction patterns.",
        "reasoning": "",
        "summary_hash": "d88ea404"
      },
      "status": "wontfix",
      "note": "All three are significant architectural changes requiring new test infrastructure or fundamental provider wiring redesign \u2014 beyond code quality improvement scope",
      "first_seen": "2026-03-15T02:05:07+00:00",
      "last_seen": "2026-03-15T02:05:07+00:00",
      "resolved_at": "2026-03-15T02:53:53+00:00",
