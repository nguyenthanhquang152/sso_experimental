    "review::.::holistic::mid_level_elegance::dual_google_claim_handoff_shapes": {
      "id": "review::.::holistic::mid_level_elegance::dual_google_claim_handoff_shapes",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Google identity claims reach ProviderIdentityNormalizer via two different shapes: raw OAuth2User.getAttribute() calls vs. typed VerifiedGoogleIdentity record",
      "detail": {
        "holistic": true,
        "dimension": "mid_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/auth/OAuth2SuccessHandler.java",
          "backend/src/main/java/com/demo/sso/service/auth/AuthCompletionService.java",
          "backend/src/main/java/com/demo/sso/service/auth/ProviderIdentityNormalizer.java"
        ],
        "evidence": [
          "OAuth2SuccessHandler.normalizeIdentity calls oAuth2User.getAttribute('sub'), getAttribute('email'), etc. and passes raw strings to providerIdentityNormalizer.normalizeGoogleClaims(sub, email, name, picture, flow).",
          "AuthCompletionService.completeGoogleAuthentication receives a VerifiedGoogleIdentity record and calls the same normalizeGoogleClaims with identity.subject(), identity.email() etc.",
          "The same logical boundary (raw Google claims \u2192 NormalizedIdentity) is crossed via two structurally different handoff shapes, meaning the ProviderIdentityNormalizer interface for Google is a raw-argument bag rather than a typed input."
        ],
        "suggestion": "Have OAuth2SuccessHandler construct a VerifiedGoogleIdentity (or a shared GoogleClaims record) from OAuth2User attributes, then call a single normalizeGoogleClaims(GoogleClaims, AuthFlow) method. This unifies the handoff shape to a single typed boundary.",
        "reasoning": "",
        "summary_hash": "e44d3c73"
      },
      "status": "wontfix",
