    "review::.::holistic::cross_module_architecture::service_pkg_mixed_concerns": {
      "id": "review::.::holistic::cross_module_architecture::service_pkg_mixed_concerns",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "service package mixes interfaces, Redis implementations, and identity value objects without subpackaging",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/AuthCodeStore.java",
          "backend/src/main/java/com/demo/sso/service/RedisAuthCodeStore.java",
          "backend/src/main/java/com/demo/sso/service/NormalizedIdentity.java",
          "backend/src/main/java/com/demo/sso/service/AuthenticatedUserIdentity.java"
        ],
        "evidence": [
          "service/ contains 12 files spanning: 2 interfaces (AuthCodeStore, MicrosoftChallengeStore), 2 Redis implementations, 2 identity value records (NormalizedIdentity, AuthenticatedUserIdentity), 2 token verifiers, and 2 identity-handling services.",
          "NormalizedIdentity and AuthenticatedUserIdentity are domain value objects that don't belong co-located with service implementations."
        ],
        "suggestion": "Split service/ into subpackages: service/store/ for AuthCodeStore+MicrosoftChallengeStore interfaces and their Redis impls, service/identity/ for NormalizedIdentity+AuthenticatedUserIdentity+ProviderIdentityNormalizer, and keep the remaining services in service/.",
        "reasoning": "",
        "summary_hash": "ae9d1f16"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-14T16:53:49+00:00",
      "last_seen": "2026-03-14T16:56:14+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "java",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::high_level_elegance::auth_controller_too_wide": {
      "id": "review::.::holistic::high_level_elegance::auth_controller_too_wide",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "AuthController conflates Google, Microsoft client-side, challenge issuance, code exchange, and logout into one class",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/AuthController.java"
        ],
        "evidence": [
          "AuthController has 5 endpoints: /google/verify, /microsoft/challenge, /microsoft/verify, /exchange, /logout \u2014 each representing a distinct flow.",
          "Class injects 8 dependencies, which is a structural signal that ownership is too wide.",
          "Microsoft challenge session cookie logic (currentChallengeSessionId, createChallengeSessionCookie, cookiePath) adds ~40 LOC of session management that could be a separate component."
        ],
        "suggestion": "Split into MicrosoftAuthController (challenge + verify) and a leaner AuthController (exchange, logout, Google verify). The cookie session logic can become a ChallengeSessionManager helper.",
        "reasoning": "",
        "summary_hash": "abb542cf"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-14T16:53:49+00:00",
      "last_seen": "2026-03-14T16:56:14+00:00",
      "resolved_at": null,
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "java",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null
    },
    "review::.::holistic::high_level_elegance::config_package_mixed_concerns": {
      "id": "review::.::holistic::high_level_elegance::config_package_mixed_concerns",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "config package groups filters, property holders, and startup guard under one ambiguous label",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/config/JwtAuthenticationFilter.java",
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthorizationGateFilter.java",
          "backend/src/main/java/com/demo/sso/config/IdentityContractGuard.java"
        ],
        "evidence": [
          "config/ holds: 2 request filters (JwtAuthenticationFilter, MicrosoftAuthorizationGateFilter), 2 property classes, 1 startup validator (IdentityContractGuard), and SecurityConfig.",
          "Filters are runtime processing components, not configuration; they belong in a filter/ or security/ subpackage."
        ],
        "suggestion": "Move JwtAuthenticationFilter and MicrosoftAuthorizationGateFilter to a security/ or filter/ subpackage. IdentityContractGuard could stay in config or move to a startup/ package.",
        "reasoning": "",
        "summary_hash": "d954ea45"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-14T16:53:49+00:00",
      "last_seen": "2026-03-14T16:56:14+00:00",
      "resolved_at": null,
