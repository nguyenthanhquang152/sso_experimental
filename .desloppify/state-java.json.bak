    "review::.::holistic::high_level_elegance::provider_feature_scattered_by_layer": {
      "id": "review::.::holistic::high_level_elegance::provider_feature_scattered_by_layer",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Provider ownership is scattered across framework layers instead of a clear feature slice",
      "detail": {
        "holistic": true,
        "dimension": "high_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/AuthController.java",
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthorizationGateFilter.java",
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthProperties.java",
          "backend/src/main/java/com/demo/sso/service/MicrosoftTokenVerifier.java",
          "backend/src/main/java/com/demo/sso/service/RedisMicrosoftChallengeStore.java",
          "frontend/src/pages/HomePage.tsx",
          "frontend/src/components/MicrosoftClientSideLogin.tsx",
          "frontend/src/hooks/useProviderConfig.ts",
          "frontend/src/types/auth.ts"
        ],
        "evidence": [
          "The backend's top-level packages under `com.demo.sso` are generic technical layers (`config`, `controller`, `model`, `repository`, `service`) rather than feature areas.",
          "Implementing or changing Microsoft auth spans `MicrosoftAuthProperties`, `MicrosoftAuthorizationGateFilter`, `AuthController`, `ProviderConfigController`, `MicrosoftTokenVerifier`, and `RedisMicrosoftChallengeStore`, which distributes one provider's behavior across multiple unrelated package owners.",
          "On the frontend, the same provider is split between `HomePage` (composition), `MicrosoftClientSideLogin` (flow), `useProviderConfig` (contract fetch), and `types/auth.ts` (public contract), so ownership is similarly reconstructed by following references instead of opening one provider-focused module."
        ],
        "suggestion": "Reorganize auth code around explicit provider-focused areas\u2014at minimum co-locate Microsoft and Google flow wiring with their public contracts, keeping only the shared identity/JWT core in common modules\u2014so a provider change is navigated through one slice instead of every framework layer.",
        "reasoning": "",
        "summary_hash": "e7b7344c"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
      "first_seen": "2026-03-14T19:10:42+00:00",
