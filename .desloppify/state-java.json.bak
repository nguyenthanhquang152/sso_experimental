    "review::.::holistic::contract_coherence::apifetch_undefined_cast": {
      "id": "review::.::holistic::contract_coherence::apifetch_undefined_cast",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "apiFetch<T> returns 'undefined as T' for 204 responses, violating its Promise<T> return type",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "frontend/src/api/client.ts"
        ],
        "evidence": [
          "Line 56: function signature is 'async function apiFetch<T>(path: string, options: RequestInit = {}): Promise<T>'",
          "Line 83-84: 'if (response.status === 204) { return undefined as T; }' \u2014 the unsafe cast silently lies about the return type",
          "Comment on line 53-55 acknowledges the issue: 'Note: Returns undefined cast to T for 204 (No Content) responses. Callers expecting 204 should check for undefined explicitly.'"
        ],
        "suggestion": "Change return type to Promise<T | undefined> or create a separate function for endpoints that may return 204. The current approach pushes type-safety responsibility onto callers via comments rather than the type system.",
        "reasoning": "",
        "summary_hash": "c4e5b986"
      },
      "status": "wontfix",
      "note": "All three are significant architectural changes requiring new test infrastructure or fundamental provider wiring redesign \u2014 beyond code quality improvement scope",
