    "review::.::holistic::api_surface_coherence::auth_controller_wildcard_responses": {
      "id": "review::.::holistic::api_surface_coherence::auth_controller_wildcard_responses",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "`AuthController` hides endpoint contracts behind wildcard response types",
      "detail": {
        "holistic": true,
        "dimension": "api_surface_coherence",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/AuthController.java",
          "backend/src/main/java/com/demo/sso/controller/ProviderConfigController.java",
          "backend/src/main/java/com/demo/sso/controller/UserController.java"
        ],
        "evidence": [
          "`AuthController.verifyGoogleToken`, `issueMicrosoftChallenge`, `verifyMicrosoftToken`, `exchangeCode`, and `logout` all declare `ResponseEntity<?>`, even though their success bodies are concrete DTOs such as `TokenResponse`, `MicrosoftChallengeResponse`, and `LogoutResponse`.",
          "Neighboring controllers publish typed signatures instead (`ProviderConfigController.getProviders(): ResponseEntity<ProviderConfigResponse>` and `UserController.getCurrentUser(): ResponseEntity<UserResponse>`), so wildcard responses are not a consistent boundary convention."
        ],
        "suggestion": "Give each `AuthController` handler a concrete success return type and route shared error serialization through one explicit mechanism (for example a common exception mapper or clearly documented `ErrorResponse` contract) so the controller signatures advertise the normal response shape.",
        "reasoning": "",
        "summary_hash": "39fffe13"
      },
      "status": "fixed",
      "note": "AuthController uses ResponseEntity<AuthApiResponse> not ResponseEntity<?> - typed response already in place",
      "first_seen": "2026-03-14T19:10:42+00:00",
      "last_seen": "2026-03-14T19:10:42+00:00",
      "resolved_at": "2026-03-14T20:30:11+00:00",
