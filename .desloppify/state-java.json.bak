    "review::.::holistic::error_consistency::validate_and_extract_context_loss": {
      "id": "review::.::holistic::error_consistency::validate_and_extract_context_loss",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "JwtTokenService.validateAndExtract() still returns Optional.empty() discarding the failure reason, despite the historical issue being marked fixed",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/token/JwtTokenService.java",
          "backend/src/main/java/com/demo/sso/config/JwtAuthenticationFilter.java"
        ],
        "evidence": [
          "JwtTokenService.java line 179-183: catch block returns Optional.empty() after logging at warn \u2014 the caller (JwtAuthenticationFilter) cannot distinguish expired token, malformed token, wrong version, or rejected contract mode",
          "JwtAuthenticationFilter.java line 51: logs 'Invalid JWT token' generically when validateAndExtract returns empty \u2014 this is a second log line for the same event (JwtTokenService already logged at warn), though the historical duplicate-logging issue was marked fixed",
          "The comment on the method says the historical issue was 'fixed' but the Optional return type inherently loses error context \u2014 a result type with Valid/Invalid(reason) variants would preserve it"
        ],
        "suggestion": "Replace Optional<AuthenticatedUserIdentity> with a sealed result type (e.g., sealed interface TokenValidationResult with Valid(identity) and Invalid(reason) variants). This lets JwtAuthenticationFilter log the specific failure reason with request context instead of duplicating a generic warning.",
        "reasoning": "",
        "summary_hash": "b7d6711e"
      },
      "status": "wontfix",
      "note": "All three are significant architectural changes requiring new test infrastructure or fundamental provider wiring redesign \u2014 beyond code quality improvement scope",
