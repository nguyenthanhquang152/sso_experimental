      "origin": "review_import",
      "lang": "java",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually Auth flow parsing via raw strings is eliminated. The legacy 5-arg findOrCreateUser was the only caller of AuthFlow.fromLoginMethod with raw strings and has been removed. All callers now pass AuthFlow enum directly via NormalizedIdentity. and I am not gaming the score.",
        "attested_at": "2026-03-14T20:47:07+00:00",
        "scan_verified": false
      }
    },
