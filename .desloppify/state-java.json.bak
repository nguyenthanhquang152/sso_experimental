    "review::.::holistic::cross_module_architecture::auth_user_bidirectional_package_dependency": {
      "id": "review::.::holistic::cross_module_architecture::auth_user_bidirectional_package_dependency",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "NormalizedIdentity in service.auth creates bidirectional package dependency with service.user",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/auth/NormalizedIdentity.java",
          "backend/src/main/java/com/demo/sso/service/user/UserService.java",
          "backend/src/main/java/com/demo/sso/service/auth/AuthCompletionService.java",
          "backend/src/main/java/com/demo/sso/service/model/AuthenticatedUserIdentity.java"
        ],
        "evidence": [
          "service.auth.AuthCompletionService imports service.user.UserService (line 5) to call findOrCreateUser()",
          "service.user.UserService imports service.auth.NormalizedIdentity (line 4) as the parameter type for findOrCreateUser()",
          "This creates bidirectional coupling: service.auth \u2192 service.user (service dependency) and service.user \u2192 service.auth (data type dependency)",
          "service.model already exists as a cross-service data type package containing AuthenticatedUserIdentity \u2014 NormalizedIdentity is analogous but does not follow this precedent"
        ],
        "suggestion": "Move NormalizedIdentity.java from service.auth to service.model, alongside AuthenticatedUserIdentity. Both are cross-service identity transfer records: AuthenticatedUserIdentity represents post-auth identity from JWT, NormalizedIdentity represents pre-auth identity from provider claims. This eliminates the bidirectional coupling and makes service.user depend only on service.model (not service.auth).",
        "reasoning": "",
        "summary_hash": "1c96b4c1"
      },
      "status": "wontfix",
      "note": "All three are significant architectural changes requiring new test infrastructure or fundamental provider wiring redesign \u2014 beyond code quality improvement scope",
      "first_seen": "2026-03-15T02:05:07+00:00",
      "last_seen": "2026-03-15T02:05:07+00:00",
      "resolved_at": "2026-03-15T02:53:53+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
