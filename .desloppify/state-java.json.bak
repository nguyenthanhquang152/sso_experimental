    "review::.::holistic::design_coherence::nullable_variant_identity": {
      "id": "review::.::holistic::design_coherence::nullable_variant_identity",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "AuthenticatedUserIdentity models two mutually exclusive identity versions via nullable fields instead of a sealed type hierarchy",
      "detail": {
        "holistic": true,
        "dimension": "design_coherence",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/model/AuthenticatedUserIdentity.java"
        ],
        "evidence": [
          "Record has 6 fields (userId, email, provider, providerUserId, contractVersion, legacyProviderKey) where 4 are nullable depending on version",
          "Line 24 comment acknowledges: 'Future: consider refactoring to a sealed interface with LegacyIdentity and V2Identity'",
          "Callers must use isLegacy() boolean to determine which fields are available, losing type-level guarantees \u2014 e.g., UserService.findCurrentUser (line 97) and JwtTokenService.parseAuthenticatedUser (lines 132-169)"
        ],
        "suggestion": "Refactor to a sealed interface with LegacyIdentity and V2Identity record implementations as the existing comment suggests. This would make the contract version a type-level guarantee and eliminate runtime isLegacy() checks.",
