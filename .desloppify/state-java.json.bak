    "review::.::holistic::logic_clarity::microsoft_nonce_check_can_be_silently_skipped": {
      "id": "review::.::holistic::logic_clarity::microsoft_nonce_check_can_be_silently_skipped",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "`validateNonce` becomes a no-op when `expectedNonce` is null",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/MicrosoftTokenVerifier.java",
          "backend/src/main/java/com/demo/sso/controller/AuthController.java"
        ],
        "evidence": [
          "`MicrosoftTokenVerifier.verifyIdToken(...)` always calls `validateNonce(jwt, expectedNonce)`, which reads like nonce verification is part of the contract.",
          "`validateNonce(...)` only throws on mismatch when `expectedNonce != null && !expectedNonce.equals(nonce)`, so passing `null` disables the check instead of failing fast.",
          "`AuthController.verifyMicrosoftToken(...)` already treats a missing stored nonce as an error before calling the verifier, which shows the intended client-side flow expects nonce presence rather than optional verification."
        ],
        "suggestion": "Make nonce presence explicit inside the verifier by rejecting `null` `expectedNonce` values for this challenged flow, or split the API into separate methods for flows that require nonce validation versus flows that intentionally do not.",
        "reasoning": "",
        "summary_hash": "0fd1406f"
      },
      "status": "fixed",
      "note": "Made MicrosoftTokenVerifier.validateNonce throw IllegalArgumentException when expectedNonce is null or blank \u2014 nonce validation can no longer be silently bypassed",
      "first_seen": "2026-03-14T19:10:42+00:00",
      "last_seen": "2026-03-14T19:10:42+00:00",
      "resolved_at": "2026-03-14T20:36:47+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "java",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually modified MicrosoftTokenVerifier.java validateNonce method and am not gaming the score",
        "attested_at": "2026-03-14T20:36:47+00:00",
        "scan_verified": false
      }
    },
    "review::.::holistic::type_safety::challenge_store_hidden_nullable_return": {
      "id": "review::.::holistic::type_safety::challenge_store_hidden_nullable_return",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "`MicrosoftChallengeStore.consumeNonce` hides a nullable result behind a plain `String` return type",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/MicrosoftChallengeStore.java",
          "backend/src/main/java/com/demo/sso/service/RedisMicrosoftChallengeStore.java",
          "backend/src/main/java/com/demo/sso/controller/AuthController.java"
        ],
        "evidence": [
          "The `MicrosoftChallengeStore` Javadoc says `consumeNonce(...)` returns `null` when the challenge is invalid or expired, but the method signature is `String consumeNonce(...)`.",
          "`RedisMicrosoftChallengeStore.consumeNonce(...)` directly returns `redisTemplate.opsForValue().getAndDelete(...)`, which can be null.",
          "`AuthController.verifyMicrosoftToken(...)` immediately has to treat the returned `String expectedNonce` as nullable and branch on `expectedNonce == null`."
        ],
        "suggestion": "Change `consumeNonce(...)` to return `Optional<String>` (or consistently annotate it as nullable) and update the controller/implementation so the type system advertises the replay/expiry case instead of hiding it in comments.",
        "reasoning": "",
        "summary_hash": "c0a14f12"
      },
      "status": "fixed",
      "note": "MicrosoftChallengeStore.consumeNonce already returns Optional<String> not a plain String \u2014 interface is correctly typed with comprehensive Javadoc documenting failure semantics",
