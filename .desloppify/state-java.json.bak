    "review::.::holistic::naming_quality::double_negative_predicate_microsoft_verify": {
      "id": "review::.::holistic::naming_quality::double_negative_predicate_microsoft_verify",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "isInvalidMicrosoftVerifyRequest uses double-negative logic \u2014 callers read 'if not invalid' instead of 'if valid'",
      "detail": {
        "holistic": true,
        "dimension": "naming_quality",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/AuthController.java"
        ],
        "evidence": [
          "AuthController line uses `if (isInvalidMicrosoftVerifyRequest(request))` which requires double-negative reasoning. The positive form `isValidMicrosoftVerifyRequest` with inverted logic would read more naturally at the call site: `if (!isValidMicrosoftVerifyRequest(request))`"
        ],
        "suggestion": "Rename to isValidMicrosoftVerifyRequest and invert the return value, so the call site reads `if (!isValidMicrosoftVerifyRequest(request))` \u2014 a standard guard clause pattern used elsewhere in the codebase.",
