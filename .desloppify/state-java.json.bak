    "review::.::holistic::convention_outlier::autowired_convention_drift": {
      "id": "review::.::holistic::convention_outlier::autowired_convention_drift",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Four service classes use explicit @Autowired on constructors while nine sibling beans use implicit constructor injection",
      "detail": {
        "holistic": true,
        "dimension": "convention_outlier",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/token/JwtTokenService.java",
          "backend/src/main/java/com/demo/sso/service/token/GoogleTokenVerifier.java",
          "backend/src/main/java/com/demo/sso/service/token/MicrosoftTokenVerifier.java",
          "backend/src/main/java/com/demo/sso/service/challenge/RedisAuthCodeStore.java"
        ],
        "evidence": [
          "JwtTokenService.java:35 has @Autowired on its constructor; GoogleTokenVerifier.java:24 has @Autowired; MicrosoftTokenVerifier.java:19 has @Autowired; RedisAuthCodeStore.java:25 has @Autowired",
          "Meanwhile AuthController, UserController, ProviderConfigController, SecurityConfig, AuthCompletionService, OAuth2SuccessHandler, UserService, IdentityContractGuard, MicrosoftAuthorizationGateFilter, RedisMicrosoftChallengeStore all use implicit constructor injection without @Autowired",
          "The historical issue reported this as 'fixed' for 3 services but all 4 still have the annotation"
        ],
        "suggestion": "Remove the @Autowired annotations from all four constructors. Since Spring 4.3+ auto-detects single constructors, the annotation is redundant and creates an inconsistency with the 9 other beans that already omit it.",
        "reasoning": "",
        "summary_hash": "e26f8a10"
      },
