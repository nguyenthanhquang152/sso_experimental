    "review::.::holistic::authorization_consistency::google_disable_policy_not_enforced_on_public_auth_routes": {
      "id": "review::.::holistic::authorization_consistency::google_disable_policy_not_enforced_on_public_auth_routes",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Google disabled-state enforcement is weaker than Microsoft's on sibling public auth routes",
      "detail": {
        "holistic": true,
        "dimension": "authorization_consistency",
        "related_files": [
          "backend/src/main/java/com/demo/sso/config/SecurityConfig.java",
          "backend/src/main/java/com/demo/sso/controller/AuthController.java",
          "backend/src/main/java/com/demo/sso/controller/ProviderConfigController.java",
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthorizationGateFilter.java",
          "backend/src/main/java/com/demo/sso/config/IdentityContractGuard.java"
        ],
        "evidence": [
          "`SecurityConfig` makes all `/oauth2/**`, `/login/oauth2/**`, and `/auth/**` endpoints public, so any provider-specific disable behavior must come from endpoint-level gates rather than the route table.",
          "`AuthController.verifyGoogleToken()` only validates that the credential is nonblank before attempting verification, while the sibling Microsoft endpoints explicitly return `503` when `rolloutProperties.getMicrosoft().isClientSideEnabled()` is false.",
          "`MicrosoftAuthorizationGateFilter` blocks `/oauth2/authorization/microsoft` and `/login/oauth2/code/microsoft` when Microsoft server-side auth is disabled, and `IdentityContractGuard` also rejects invalid Microsoft-enabled startup states.",
          "`ProviderConfigController` can publish Google as unavailable when `googleClientId` is blank, but there is no equivalent Google request-time or startup guard to keep the public Google auth routes aligned with that advertised disabled state."
        ],
        "suggestion": "Derive provider availability from one shared fail-closed check and apply it consistently to both Google and Microsoft auth entry points. At minimum, guard the public Google auth endpoints (`/auth/google/verify` and any Google OAuth redirect entrypoint) with the same disabled/configured policy that `GET /auth/providers` publishes, returning a consistent disabled response instead of relying on downstream verifier behavior.",
        "reasoning": "",
        "summary_hash": "a493b0a7"
      },
      "status": "fixed",
      "note": "Added Google rollout guard to AuthController.verifyGoogleToken \u2014 mirrors Microsoft's pattern checking rolloutProperties.getGoogle().isClientSideEnabled(). Added Google section to AuthRolloutProperties with clientSideEnabled defaulting true",
      "first_seen": "2026-03-14T19:10:42+00:00",
      "last_seen": "2026-03-14T19:10:42+00:00",
      "resolved_at": "2026-03-14T20:36:17+00:00",
      "reopen_count": 0,
      "work_item_kind": "review_defect",
      "issue_kind": "review_defect",
      "origin": "review_import",
      "lang": "java",
      "suppressed": false,
      "suppressed_at": null,
      "suppression_pattern": null,
      "resolution_attestation": {
        "kind": "manual",
        "text": "I have actually modified AuthController.java and AuthRolloutProperties.java and am not gaming the score",
        "attested_at": "2026-03-14T20:36:17+00:00",
        "scan_verified": false
      }
