    "review::.::holistic::error_consistency::silent_auth_code_exchange_failure": {
      "id": "review::.::holistic::error_consistency::silent_auth_code_exchange_failure",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "The homepage silently swallows auth-code exchange failures at the login boundary.",
      "detail": {
        "holistic": true,
        "dimension": "error_consistency",
        "related_files": [
          "frontend/src/pages/HomePage.tsx"
        ],
        "evidence": [
          "`HomePage` exchanges `?code=` through `apiFetch('/auth/exchange')` and then uses `.catch(() => { /* Code was invalid or expired \u2014 stay on homepage */ })` with no log, no telemetry, and no visible error state.",
          "That means an expired code and a network failure both collapse into the same 'nothing happened' outcome, making the failure mode impossible to distinguish during debugging or normal use."
        ],
