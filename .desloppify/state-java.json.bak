    "review::.::holistic::dependency_health::google_api_client_heavy_for_scope": {
      "id": "review::.::holistic::dependency_health::google_api_client_heavy_for_scope",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "low",
      "summary": "google-api-client is a heavy transitive dependency used only for GoogleIdTokenVerifier",
      "detail": {
        "holistic": true,
        "dimension": "dependency_health",
        "related_files": [
          "backend/pom.xml",
          "backend/src/main/java/com/demo/sso/service/GoogleTokenVerifier.java"
        ],
        "evidence": [
          "pom.xml includes com.google.api-client:google-api-client:2.7.2",
          "Only usage: new GoogleIdTokenVerifier.Builder(new NetHttpTransport(), GsonFactory.getDefaultInstance()).setAudience(...).build()",
          "Spring Security OAuth2 Resource Server (already a dependency) has JwtDecoder which could verify Google ID tokens using Google's JWKS endpoint."
        ],
        "suggestion": "Replace google-api-client with NimbusJwtDecoder.withJwkSetUri(\"https://www.googleapis.com/oauth2/v3/certs\") and validate the audience claim manually, removing the heavy google-api-client transitive dependency.",
        "reasoning": "",
        "summary_hash": "1f300327"
      },
      "status": "open",
      "note": null,
      "first_seen": "2026-03-14T16:56:14+00:00",
      "last_seen": "2026-03-14T16:56:14+00:00",
      "resolved_at": null,
