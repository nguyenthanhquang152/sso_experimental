    "review::.::holistic::contract_coherence::exception_handler_leaks_messages": {
      "id": "review::.::holistic::contract_coherence::exception_handler_leaks_messages",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "GlobalExceptionHandler surfaces raw IllegalArgumentException messages as 400 response bodies",
      "detail": {
        "holistic": true,
        "dimension": "contract_coherence",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/GlobalExceptionHandler.java"
        ],
        "evidence": [
          "Line 16-18: 'handleIllegalArgument' returns 'new ErrorResponse(e.getMessage())' \u2014 the raw exception message becomes the HTTP response body",
          "AuthController endpoint methods catch their own IllegalArgumentException cases and return sanitized messages (e.g., 'Invalid Google credential')",
          "If an uncaught IllegalArgumentException from a deep service layer (e.g., ProviderIdentityNormalizer, JwtTokenService) reaches the handler, its internal message (e.g., 'V2 JWT is missing required identity claims') would be exposed to clients"
        ],
        "suggestion": "Return a generic 'Bad request' message in the GlobalExceptionHandler fallback and log the specific exception message at WARN level (already done), rather than forwarding internal exception messages to clients.",
