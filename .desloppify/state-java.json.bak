      },
      "status": "fixed",
      "note": "AuthController no longer imports com.google.api.client.googleapis.auth.oauth2.GoogleIdToken. The Google SDK is fully encapsulated within GoogleTokenVerifier. Tests also updated to use VerifiedGoogleIdentity instead of GoogleIdToken.Payload.",
