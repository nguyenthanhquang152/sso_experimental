    "review::.::holistic::low_level_elegance::normalizeEmail_redundant_indexOf": {
      "id": "review::.::holistic::low_level_elegance::normalizeEmail_redundant_indexOf",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "normalizeEmail() calls indexOf('@') three times when atIndex is already computed on the previous line",
      "detail": {
        "holistic": true,
        "dimension": "low_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/auth/ProviderIdentityNormalizer.java"
        ],
        "evidence": [
          "Line 79 computes `int atIndex = normalized.indexOf('@')`. Line 80 then calls `normalized.indexOf('@')` twice more and `normalized.lastIndexOf('@')` once in the hasExactlyOneAt expression, ignoring the already-computed atIndex variable. The fix is to rewrite as `boolean hasExactlyOneAt = atIndex >= 0 && atIndex == normalized.lastIndexOf('@')`."
        ],
        "suggestion": "Replace line 80 with: `boolean hasExactlyOneAt = atIndex >= 0 && atIndex == normalized.lastIndexOf('@');` \u2014 this eliminates two redundant indexOf calls and makes the validation intent clearer.",
        "reasoning": "",
        "summary_hash": "8ab21da3"
      },
      "status": "wontfix",
