    "review::.::holistic::cross_module_architecture::auth_edge_orchestration_hub": {
      "id": "review::.::holistic::cross_module_architecture::auth_edge_orchestration_hub",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "Authentication completion is duplicated across web entrypoints instead of living behind one application-service boundary.",
      "detail": {
        "holistic": true,
        "dimension": "cross_module_architecture",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/AuthController.java",
          "backend/src/main/java/com/demo/sso/service/OAuth2SuccessHandler.java",
          "backend/src/main/java/com/demo/sso/service/UserService.java",
          "backend/src/main/java/com/demo/sso/service/JwtTokenService.java"
        ],
        "evidence": [
          "`AuthController.verifyGoogleToken()` normalizes claims, upserts the user, and mints a JWT inline; `verifyMicrosoftToken()` repeats the same completion workflow for a different provider.",
          "`OAuth2SuccessHandler.onAuthenticationSuccess()` repeats the normalized-identity -> `userService.findOrCreateUser()` -> `jwtTokenService.generateToken()` -> `authCodeStore.storeJwt()` sequence for server-side logins.",
          "`AuthController` also owns Microsoft challenge-session cookie handling and auth-code exchange, making one controller the coordination point for several auth sub-protocols rather than a thin transport adapter."
        ],
        "suggestion": "Extract a provider-neutral authentication application service that owns normalized-identity completion, JWT minting, and auth-code issuance, then keep controllers and success handlers focused on HTTP/OAuth protocol translation only.",
        "reasoning": "",
        "summary_hash": "195f4dc9"
      },
      "status": "fixed",
      "note": "not reported in latest holistic re-import",
