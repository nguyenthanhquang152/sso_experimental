    "review::.::holistic::naming_quality::firstnonblank_generic_utility_name": {
      "id": "review::.::holistic::naming_quality::firstnonblank_generic_utility_name",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "firstNonBlank() in ProviderIdentityNormalizer is a generic utility name in domain code where email resolution semantics matter",
      "detail": {
        "holistic": true,
        "dimension": "naming_quality",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/auth/ProviderIdentityNormalizer.java"
        ],
        "evidence": [
          "firstNonBlank(claims.email(), claims.preferredUsername(), claims.upn()) resolves the email claim from Microsoft's priority cascade (email > preferred_username > upn), but the method name 'firstNonBlank' describes the mechanism, not the intent. A reader scanning normalizeMicrosoftClaims must trace into the helper to understand it implements Microsoft's email-resolution priority."
        ],
        "suggestion": "Rename to resolveEmailClaim or selectPrimaryEmailClaim to communicate that this implements Microsoft's email claim priority cascade, not just a generic null-coalescing utility.",
