    "review::.::holistic::type_safety::auth_flow_legacy_string_contract": {
      "id": "review::.::holistic::type_safety::auth_flow_legacy_string_contract",
      "detector": "review",
      "file": ".",
      "tier": 2,
      "confidence": "medium",
      "summary": "Auth flow parsing still uses raw strings and `null` even though `AuthFlow` is the codebase enum",
      "detail": {
        "holistic": true,
        "dimension": "type_safety",
        "related_files": [
          "backend/src/main/java/com/demo/sso/model/AuthFlow.java",
          "backend/src/main/java/com/demo/sso/service/UserService.java",
          "backend/src/main/java/com/demo/sso/model/User.java"
        ],
        "evidence": [
          "`AuthFlow.fromLoginMethod(String)` returns `null` for blank or invalid input even though its signature advertises a concrete `AuthFlow` result.",
          "`UserService.findOrCreateUser(String googleId, String email, String name, String pictureUrl, String loginMethod)` accepts a raw string and then converts it with `AuthFlow.fromLoginMethod(...)` instead of taking the enum directly.",
          "`User` stores both `loginMethod` as `String` and `lastLoginFlow` as `AuthFlow`, so the same concept exists in parallel typed and stringly forms."
        ],
        "suggestion": "Make public service APIs consume `AuthFlow` (or `Optional<AuthFlow>` for parse results), keep raw login-method strings only at persistence/serialization boundaries, and remove `null` as the implicit parse-failure signal.",
        "reasoning": "",
        "summary_hash": "3fe49f96"
      },
      "status": "fixed",
      "note": "Auth flow parsing via raw strings is eliminated. The legacy 5-arg findOrCreateUser was the only caller of AuthFlow.fromLoginMethod with raw strings and has been removed. All callers now pass AuthFlow enum directly via NormalizedIdentity.",
      "first_seen": "2026-03-14T19:10:42+00:00",
      "last_seen": "2026-03-14T19:10:42+00:00",
      "resolved_at": "2026-03-14T20:47:07+00:00",
      "reopen_count": 0,
