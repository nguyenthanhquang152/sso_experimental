    "review::.::holistic::initialization_coupling::google_verifier_heavy_constructor": {
      "id": "review::.::holistic::initialization_coupling::google_verifier_heavy_constructor",
      "detector": "review",
      "file": ".",
      "tier": 3,
      "confidence": "low",
      "summary": "GoogleTokenVerifier constructs a GoogleIdTokenVerifier (with HTTP transport) in the constructor",
      "detail": {
        "holistic": true,
        "dimension": "initialization_coupling",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/GoogleTokenVerifier.java"
        ],
        "evidence": [
          "Constructor: this.verifier = new GoogleIdTokenVerifier.Builder(new NetHttpTransport(), GsonFactory.getDefaultInstance()).setAudience(...).build()",
          "NetHttpTransport is created inline at construction time, creating a dependency on network infrastructure at bean initialization.",
          "No actual network call is made at construction, but the HTTP client is initialized."
        ],
        "suggestion": "Consider extracting verifier construction to a @Bean factory method in a config class, making the HTTP transport mockable for tests. Alternatively, accept the current pattern as reasonable since no network I/O occurs at startup.",
        "reasoning": "",
        "summary_hash": "964957c4"
      },
      "status": "open",
      "note": null,
