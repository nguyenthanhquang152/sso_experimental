    "review::.::holistic::logic_clarity::normalize_email_unused_atindex": {
      "id": "review::.::holistic::logic_clarity::normalize_email_unused_atindex",
      "detector": "review",
      "file": ".",
      "tier": 1,
      "confidence": "high",
      "summary": "normalizeEmail declares atIndex variable but recomputes indexOf('@') three more times instead of using it",
      "detail": {
        "holistic": true,
        "dimension": "logic_clarity",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/auth/ProviderIdentityNormalizer.java"
        ],
        "evidence": [
          "Line 78: `int atIndex = normalized.indexOf('@');` declares the variable",
          "Line 79: `boolean hasExactlyOneAt = normalized.indexOf('@') == normalized.lastIndexOf('@') && normalized.indexOf('@') >= 0;` recomputes indexOf('@') three times instead of using atIndex",
          "The hasExactlyOneAt check also includes `indexOf('@') >= 0` which is redundant with hasNonEmptyLocalAndDomain's `atIndex > 0` check (atIndex > 0 implies atIndex >= 0)"
        ],
        "suggestion": "Rewrite hasExactlyOneAt to use the already-computed atIndex: `boolean hasExactlyOneAt = atIndex >= 0 && atIndex == normalized.lastIndexOf('@');` \u2014 this eliminates three redundant indexOf calls and makes the relationship between the checks clearer",
        "reasoning": "",
        "summary_hash": "30b3cbcf"
      },
