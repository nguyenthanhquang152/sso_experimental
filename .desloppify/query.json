      "id": "review::.::holistic::mid_level_elegance::server_side_auth_errors_are_dropped",
      "confidence": "high",
      "detector": "review",
      "file": ".",
      "summary": "Backend redirect errors for server-side auth are never consumed by the homepage",
      "detail": {
        "holistic": true,
        "dimension": "mid_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/service/OAuth2SuccessHandler.java",
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthorizationGateFilter.java",
          "frontend/src/pages/HomePage.tsx"
        ],
        "evidence": [
          "`OAuth2SuccessHandler` redirects failed OAuth logins to `/?error=email_not_verified` and `/?error=missing_attributes`.",
          "`MicrosoftAuthorizationGateFilter` redirects disabled Microsoft callbacks to `/?error=provider_disabled&provider=microsoft&flow=server_side`.",
          "`HomePage` only reads `searchParams.get('code')`; there is no frontend handling for `error`, `provider`, or `flow`, so those backend outcomes never become a user-visible auth result."
        ],
        "suggestion": "Define one shared server-side auth result contract: either parse and display the backend's error query parameters in `HomePage` or funnel both success and failure redirects through a single helper so the frontend handles auth callback outcomes in one place.",
        "reasoning": "",
        "summary_hash": "fca79a56"
      },
      "status": "open",
