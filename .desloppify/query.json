      "id": "review::.::holistic::mid_level_elegance::microsoft_provider_contract_hides_redirect_uri",
      "confidence": "high",
      "detector": "review",
      "file": ".",
      "summary": "Microsoft client-side auth config stops short of the actual redirect target",
      "detail": {
        "holistic": true,
        "dimension": "mid_level_elegance",
        "related_files": [
          "backend/src/main/java/com/demo/sso/controller/ProviderConfigController.java",
          "backend/src/main/java/com/demo/sso/controller/dto/ProviderConfigResponse.java",
          "frontend/src/types/auth.ts",
          "frontend/src/components/MicrosoftClientSideLogin.tsx"
        ],
        "evidence": [
          "`ProviderConfigController.getProviders()` exposes Microsoft `clientId`, `authority`, and `scopes`, but `ProviderConfigResponse.MicrosoftProviderConfig` has no redirect URI field.",
          "`frontend/src/types/auth.ts` mirrors that contract exactly, so the frontend has no backend-owned redirect target to consume.",
          "`MicrosoftClientSideLogin` creates MSAL with `redirectUri: window.location.origin`, making the callback URL depend on the serving origin instead of the published provider configuration."
        ],
        "suggestion": "Extend the `/auth/providers` Microsoft contract to publish the redirect URI (or an equivalent backend-owned callback descriptor) and have `MicrosoftClientSideLogin` consume that shared value so every environment derives the same MSAL configuration from one seam.",
        "reasoning": "",
        "summary_hash": "a31edb04"
      },
