      "id": "review::.::holistic::naming_quality::microsoft_is_configured_alias_hides_readiness_level",
      "confidence": "medium",
      "detector": "review",
      "file": ".",
      "summary": "`isConfigured()` obscures whether Microsoft auth is client-side or server-side ready",
      "detail": {
        "holistic": true,
        "dimension": "naming_quality",
        "related_files": [
          "backend/src/main/java/com/demo/sso/config/MicrosoftAuthProperties.java",
          "backend/src/main/java/com/demo/sso/service/MicrosoftTokenVerifier.java"
        ],
        "evidence": [
          "`MicrosoftAuthProperties` defines both `isClientSideConfigured()` and `isServerSideConfigured()`, but the generic `isConfigured()` just aliases the client-side check.",
          "`MicrosoftTokenVerifier.buildDecoder(...)` calls `properties.isConfigured()`, so readers have to open the implementation to learn which configuration level that generic name actually means."
        ],
        "suggestion": "Replace `isConfigured()` with a name that states the exact readiness level it represents, such as `isTokenVerificationConfigured()`, or call the explicit client/server-specific predicate directly at each use site.",
        "reasoning": "",
        "summary_hash": "dd8dd968"
      },
